# ── Pharos Atlantic Testnet ───────────────────────────────────────────────
# Verified: ChainID 688689, native token PHRS, limit 500 req / 5 min.
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689

# SentinelRegistry contract address (fill after `forge script Deploy`).
SENTINEL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Attester key — the wallet that signs/pays for on-chain attestation writes.
# NEVER commit a real key. Use a throwaway testnet key funded from the faucet.
# If left empty, the MCP tools still return verdicts but skip the on-chain write.
ATTESTER_PRIVATE_KEY=

# ── GoPlus Security API ───────────────────────────────────────────────────
# Free, no key needed for the basic tier (30 calls/min). Token only raises limits.
GOPLUS_BASE_URL=https://api.gopluslabs.io/api/v1
GOPLUS_ACCESS_TOKEN=

# ── CertiK Skill Scanner ──────────────────────────────────────────────────
# NO public self-serve API confirmed (Jun 2026). Leave empty -> built-in local
# heuristic engine is used. Set both to enable the feature-flagged real adapter
# IF/WHEN CertiK grants access. Do NOT hardcode an unverified endpoint.
CERTIK_SKILL_SCANNER_URL=
CERTIK_API_KEY=

# ── Policy ────────────────────────────────────────────────────────────────
SENTINEL_POLICY_PATH=./policies/default.yaml
